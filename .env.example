# Required: PortaSplit address in the IoT VLAN.
# The Midea app may display this byte-swapped, e.g. 49.0.20.10 usually means 10.20.0.49.
MIDEA_HOST=10.20.0.49
MIDEA_PORT=6444

# Optional: direct V3 credentials. Leave empty to let msmart-ng authenticate via discovery/cloud.
# Treat these like passwords and do not commit them.
MIDEA_ID=
MIDEA_TOKEN=
MIDEA_KEY=

# Optional cloud login. Usually not needed for discovery if msmart-ng built-in credentials work.
MIDEA_REGION=DE
MIDEA_ACCOUNT=
MIDEA_PASSWORD=

POLL_INTERVAL=30
QUERY_ENERGY=true
QUERY_CAPABILITIES=false
LOG_LEVEL=INFO

# HTTP API for FHEM HTTPMOD or debugging.
HTTP_ENABLE=true
HTTP_HOST=0.0.0.0
HTTP_PORT=8765

# MQTT for FHEM MQTT2. Enable when an MQTT broker or FHEM MQTT2_SERVER is reachable.
MQTT_ENABLE=false
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=fhem/midea/portasplit

